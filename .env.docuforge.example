# DocuForge — required environment variables for deployment.
# Copy to .env next to compose.docuforge.yaml and fill in real values.

# ── Auth (Supabase project: Settings → API) ──────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_ANON_KEY=...

# Comma-separated whitelist of emails allowed to sign up.
# Signup is DISABLED if this is empty (fail closed).
ALLOWED_EMAILS=you@example.com,friend@example.com

# ── LLMs ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL_FAST=llama-3.3-70b-versatile
GROQ_MODEL_LONG=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_REASON=qwen/qwen3-32b
# Gemini fallback
GOOGLE_API_KEY=...

# ── Research agent web search ────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Optional: LangSmith tracing ──────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=docuforge

# ── Storage ──────────────────────────────────────────────────────────────
# Inside the container this is overridden to /data/faiss_index (named volume).
FAISS_INDEX_DIR=./faiss_index
